# Werte NIE hier eintragen — nur Referenz, welche Env-Vars der Proxy liest.
# Auf Hostinger werden diese via SetEnv in der Passenger-.htaccess gesetzt (siehe README).

# Kimi-Key. sk-kim… = Kimi CODE (api.kimi.com), sk-… (sonst) = Moonshot.
KIMI_API_KEY=

# Zugangscode-Gate = Proxy-Token. PFLICHT: ist er leer, fällt das Gate zu (503).
# Frischen, nicht-erratbaren Wert wählen — NICHT "kb-demo" (steht in der Git-History).
# Muss dem Code entsprechen, den der Client sendet (?kicode=… / kiUnlock()).
KI_SHARED_TOKEN=

# Globales Tageslimit (Calls/Tag, hartes Ceiling da kein Kimi-Spend-Cap). Default 400.
KI_DAILY_MAX=

# Endpunkt (Default im Code = Kimi Code):
#   Kimi Code: KIMI_HOST=api.kimi.com   KIMI_PATH=/coding/v1/chat/completions
#   Moonshot : KIMI_HOST=api.moonshot.ai KIMI_PATH=/v1/chat/completions
KIMI_HOST=
KIMI_PATH=

# Modell. Kimi Code: kimi-for-coding (KANN Vision!) | k3 | k3-256k | kimi-for-coding-highspeed
KIMI_MODEL=
KIMI_VISION_MODEL=

# kimi-for-coding erlaubt NUR temperature=1 (Default). Moonshot: z.B. 0.3.
KIMI_TEMP=
